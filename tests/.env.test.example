# ── Copy this to .env.test and fill in your local Supabase values ──
# Run: supabase start   to get SUPABASE_URL + keys
# Run: supabase status  to print them

# Local Supabase (supabase start)
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Dashboard served locally (e.g. npx serve . -p 3000 from project root)
DASHBOARD_URL=http://localhost:3000

# JWT secret — must match what you set in supabase secrets
JWT_SECRET=super-secret-jwt-key-at-least-32-characters-long

# Shopify — use dummy values for unit/edge-function tests; real creds for integration
SHOPIFY_CLIENT_ID=test_shopify_client_id
SHOPIFY_CLIENT_SECRET=test_shopify_client_secret_32chars

# Meta — use dummy values for unit/edge-function tests
META_APP_ID=1234567890
META_APP_SECRET=test_meta_app_secret_hex_value_here

# App URL (redirect target after OAuth)
APP_URL=http://localhost:3000

# Playwright test accounts (created by global-setup.ts)
TEST_OWNER_EMAIL=test.owner@blue-agency-test.com
TEST_OWNER_PASSWORD=TestOwner1234!
TEST_ADMIN_EMAIL=test.admin@blue-agency-test.com
TEST_ADMIN_PASSWORD=TestAdmin1234!
TEST_ANALYST_EMAIL=test.analyst@blue-agency-test.com
TEST_ANALYST_PASSWORD=TestAnalyst1234!
TEST_VIEWER_EMAIL=test.viewer@blue-agency-test.com
TEST_VIEWER_PASSWORD=TestViewer1234!
